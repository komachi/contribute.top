{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Project"
      },
      "uniqueItemProperties": ["id", "title"]
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Tool"
      },
      "uniqueItemProperties": ["id", "title"]
    }
  },
  "required": ["$schema", "projects", "tools"],
  "definitions": {
    "AppId": {
      "type": "string",
      "pattern": "^(?:[a-zA-Z]+(?:\\d*[a-zA-Z_]*)*)(?:\\.[a-zA-Z]+(?:\\d*[a-zA-Z_]*)*)+$"
    },
    "AppStoreId": {
      "type": "number"
    },
    "URL": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://"
    },
    "QID": {
      "type": "string",
      "pattern": "^Q\\d+$"
    },
    "Category": {
      "type": "string",
      "enum": [
        "writing",
        "software",
        "hardware",
        "data",
        "audio",
        "graphics",
        "photos",
        "translation",
        "location",
        "science"
      ]
    },
    "Hardware": {
      "type": "string",
      "enum": [
        "pc",
        "phone",
        "server",
        "sdr",
        "weather_station",
        "lora",
        "camera",
        "microphone",
        "uav",
        "geiger_counter",
        "air_quality_monitor",
        "lightning_detector",
        "noise_sensor"
      ]
    },
    "Platform": {
      "type": "string",
      "enum": [
        "web",
        "android",
        "ios",
        "linux",
        "windows",
        "macos",
        "esp32",
        "nrf52"
      ]
    },
    "Links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "website": {
          "$ref": "#/definitions/URL"
        },
        "sourcecode": {
          "$ref": "#/definitions/URL"
        },
        "fdroid": {
          "$ref": "#/definitions/AppId"
        },
        "googleplay": {
          "$ref": "#/definitions/AppId"
        },
        "appstore": {
          "$ref": "#/definitions/AppStoreId"
        },
        "flathub": {
          "$ref": "#/definitions/AppId"
        }
      }
    },
    "Project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "categories": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Category"
          }
        },
        "hardware": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Hardware"
          }
        },
        "website": {
          "$ref": "#/definitions/URL"
        },
        "wikidata": {
          "$ref": "#/definitions/QID"
        },
        "enwiki": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "categories",
        "hardware",
        "website"
      ]
    },
    "Tool": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "$ref": "#/definitions/Links"
        },
        "hardware": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Hardware"
          }
        },
        "platforms": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Platform"
          }
        },
        "wikidata": {
          "$ref": "#/definitions/QID"
        },
        "enwiki": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "projects",
        "links",
        "hardware",
        "platforms"
      ]
    }
  }
}
