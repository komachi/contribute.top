{
  "name": "contribute.top",
  "private": true,
  "type": "module",
  "license": "CC-BY-SA-4.0",
  "homepage": "https://contribute.top",
  "author": {
    "name": "Anton Nesterov",
    "email": "anton@nesterov.cc",
    "url": "https://nesterov.cc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komachi/contribute.top.git"
  },
  "scripts": {
    "prepare": "run-p husky codegen:types codegen:reactrouter codegen:pwa-assets",
    "husky": "husky",
    "codegen:types": "json2ts --unknownAny app/data/data.schema.json app/types.ts",
    "codegen:reactrouter": "react-router typegen",
    "codegen:pwa-assets": "pwa-assets-generator",
    "build": "react-router build",
    "dev": "react-router dev",
    "typecheck": "run-s codegen:types codegen:reactrouter tsc",
    "tsc": "tsc",
    "check": "biome check",
    "test": "run-p check test:json typecheck",
    "test:json": "ajv validate -s app/data/data.schema.json -d 'app/data/data.json' -c ajv-formats -c ajv-keywords",
    "wikidata": "ts-node scripts/wikidata.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/react": "^1.1.0",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "isbot": "^5",
    "jsonata": "^2.2.1",
    "nanostores": "^1.4.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router": "^8.0.1",
    "react-schemaorg": "^2.0.1",
    "remark-gfm": "^4.0.1",
    "schema-dts": "^2.0.0",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@chakra-ui/cli": "^3.36.0",
    "@react-router/dev": "^8.0.1",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "ajv-keywords": "^5.1.0",
    "autoprefixer": "^10.5.2",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "npm-check-updates": "^22.2.9",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-sitemap": "^0.8.2",
    "wikibase-sdk": "^11.6.3"
  }
}
